<%# Single-page app shell. app/javascript/application.js owns the entire
    phase state machine (input -> reading -> reviewing) and renders into
    the placeholders below, mirroring the React component's responsibilities. %>

<div id="app" data-editors="<%= @editors.map { |e|
      { key: e.key, name: e.name, author: e.author, source: e.source,
        focus: e.focus, useCase: e.use_case, available: e.available,
        lead: e.details[:lead] }
    }.to_json %>">
  <header id="header">
    <div class="header-inner">
      <div class="logo">
        <span class="logo-main">editwise</span>
        <span class="logo-sub">/ The AI editor that makes you a better writer.</span>
      </div>
      <div id="header-actions"></div>
    </div>
  </header>

  <main id="main"></main>

  <div id="footer-nav"></div>
</div>

<template id="tpl-input-phase">
  <main class="phase-input">
    <div class="intro">
      <h1>Write fast, edit slowly.</h1>
      <div class="subhead">Human-speed editing for the age of AI.</div>
      <p>Most AI editing leaves you feeling like you've been through a washing machine. Twenty changes at once, everything blurred together, and at the end you can't quite tell what's still yours.</p>
      <p>This works the other way. One editor at a time. One revision at a time. The whole essay stays in front of you. You see exactly what each suggestion would change. Then you accept it, decline it, or rewrite it yourself.</p>
    </div>

    <textarea id="paste-input" placeholder="Paste your essay here…"></textarea>

    <div class="input-actions">
      <button class="btn-ghost" id="load-demo-btn">Load demo essay</button>
      <button class="btn-primary" id="continue-btn" disabled>Continue →</button>
    </div>

    <div class="editors-section">
      <div class="mono-label">
        <span>Editors</span>
        <span class="mono-sublabel">· click any editor to read about its philosophy and principles</span>
      </div>
      <div class="editors-grid" id="editor-cards"></div>
    </div>
  </main>
</template>

<template id="tpl-editor-card">
  <button class="editor-card">
    <div class="editor-card-name"></div>
    <div class="editor-card-author"></div>
    <div class="editor-card-focus"></div>
    <div class="editor-card-readmore">Read more →</div>
  </button>
</template>

<template id="tpl-reading-phase">
  <main class="phase-reading">
    <div class="editor-picker">
      <div class="mono-label" id="picker-label">Pick an editor</div>
      <div class="editor-compact-grid" id="editor-compact-cards"></div>
    </div>

    <div class="running-banner" id="running-banner" hidden>
      <span class="reading-dot"></span>
      <div>
        <div class="running-banner-title" id="running-banner-title">Editor is reading</div>
        <div class="running-banner-body">Going through your essay one paragraph at a time. This usually takes ten to twenty seconds.</div>
      </div>
    </div>

    <div class="status-bar">
      <div class="status-left" id="status-left"></div>
      <button class="btn-ghost" id="copy-essay-btn" hidden>Copy essay</button>
    </div>

    <div class="error-box" id="error-box" hidden></div>

    <div class="verdict-card" id="verdict-card" hidden>
      <div class="mono-label">Verdict</div>
      <div class="verdict-text" id="verdict-text"></div>
    </div>

    <div class="all-resolved-banner" id="all-resolved-banner" hidden>
      <div class="mono-label">Pass complete</div>
      <div id="all-resolved-text"></div>
    </div>

    <article class="essay-prose" id="essay-prose"></article>
  </main>
</template>

<template id="tpl-editor-compact-card">
  <div class="compact-card" tabindex="0" role="button">
    <button type="button" class="info-button">?</button>
    <div class="compact-card-name"></div>
    <div class="compact-card-author"></div>
    <div class="compact-card-usecase"></div>
  </div>
</template>

<template id="tpl-revision-card">
  <span class="rev-card">
    <span class="rev-principle"></span>
    <div class="rev-body"></div>
    <div class="rev-explanation"></div>
    <div class="rev-actions"></div>
    <div class="rev-discussion" hidden></div>
  </span>
</template>

<div id="editor-info-modal" hidden>
  <div id="editor-info-backdrop"></div>
  <div id="editor-info-card">
    <div id="editor-info-name"></div>
    <div id="editor-info-byline"></div>
    <div id="editor-info-lead"></div>
    <div id="editor-info-actions">
      <a id="editor-info-readmore" class="btn-ghost">Read more →</a>
      <button id="editor-info-close" class="btn-ghost">Close</button>
    </div>
  </div>
</div>
